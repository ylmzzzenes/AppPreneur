# Production Docker Compose — UniFlow (API + PostgreSQL + Web gateway)
# Copy to .env.production on the Hetzner server (do not commit secrets).

# =============================================================================
# PostgreSQL
# =============================================================================
POSTGRES_DB=uniflow
POSTGRES_USER=uniflow
POSTGRES_PASSWORD=change-me-strong-password

DATABASE_PROVIDER=PostgreSql

# =============================================================================
# JWT (minimum 32 characters)
# =============================================================================
JWT_KEY=change-me-production-jwt-secret-32chars-min

# =============================================================================
# API (internal only — exposed via web/nginx gateway on port 80)
# =============================================================================
ASPNETCORE_ENVIRONMENT=Production

# =============================================================================
# AI / OCR (same as local .env.example)
# =============================================================================
Ai__Provider=Gemini
Ai__ApiKey=
Ai__Model=gemini-2.5-flash
Ai__EnableFallback=true
GEMINI_API_KEY=

UniFlow__Ocr__Provider=Gemini

# =============================================================================
# CORS (optional — same-origin web in prod does not need CORS)
# Phase A: web on :3000 needs API to allow http://49.13.89.74:3000
# Applied via deploy/phase-a/api-cors.override.yml (does not touch .env.production)
# Phase B domain example:
# Cors__AllowedOrigins__0=https://app.example.com

# =============================================================================
# Web gateway port (host nginx should proxy to this, or bind directly)
# =============================================================================
WEB_PORT=80

# Copy to .env and adjust for local Docker Compose (do not commit .env)
#   Copy-Item .env.example .env

# =============================================================================
# PostgreSQL (docker compose postgres service)
# =============================================================================
POSTGRES_DB=uniflow
POSTGRES_USER=uniflow
POSTGRES_PASSWORD=uniflow_dev_password
POSTGRES_PORT=5432

DATABASE_PROVIDER=PostgreSql
# Used only when running API outside Docker against the compose Postgres container:
# CONNECTION_STRING=Host=localhost;Port=5432;Database=uniflow;Username=uniflow;Password=uniflow_dev_password

# =============================================================================
# API ports
# =============================================================================
API_PORT=5000

# Required for API startup (minimum 32 characters)
JWT_KEY=dev-jwt-secret-change-me-32chars-min

# =============================================================================
# AI provider (ASP.NET Core: Ai__* → Ai section)
# =============================================================================
# Provider: Gemini | OpenAiCompatible | Fake
# Fake = keyless demo (Development/Testing only; blocked in Production)
Ai__Provider=Gemini
Ai__ApiKey=
Ai__BaseUrl=https://api.openai.com/v1
Ai__Model=gemini-2.5-flash
Ai__TimeoutSeconds=30
Ai__RetryCount=2
Ai__PromptVersion=v1
Ai__EnableFallback=true
Ai__LogMetadataOnly=true
# Optional: override embedded chat system prompt (empty = Sarkastik Dahi default)
# Ai__ChatSystemPrompt=

# Alternate keys — applied when Ai__ApiKey is empty:
# AI_API_KEY=your-key
# GEMINI_API_KEY=your-google-ai-studio-key

# Legacy UniFlow:Gemini section (optional; maps to Ai when Ai__ApiKey empty)
# UniFlow__Gemini__ApiKey=
# UniFlow__Gemini__Model=gemini-2.5-flash
# UniFlow__Gemini__TimeoutSeconds=120

# --- OpenRouter (set Ai__Provider=OpenAiCompatible) ---
# Ai__Provider=OpenAiCompatible
# Ai__BaseUrl=https://openrouter.ai/api/v1
# Ai__Model=meta-llama/llama-3.2-3b-instruct:free
# Ai__ApiKey=your-openrouter-key

# --- Groq (set Ai__Provider=OpenAiCompatible) ---
# Ai__Provider=OpenAiCompatible
# Ai__BaseUrl=https://api.groq.com/openai/v1
# Ai__Model=llama-3.1-8b-instant
# Ai__ApiKey=your-groq-key

# --- Fake provider (keyless local demo) ---
# Ai__Provider=Fake
# Ai__Model=fake-model

# =============================================================================
# OCR (syllabus scan)
# =============================================================================
# Stub = text-only files, no PNG/PDF images (no API key)
# Gemini = multimodal OCR, reuses Ai__ApiKey / GEMINI_API_KEY
# Azure = requires UniFlow__Ocr__Azure__Endpoint + key
UniFlow__Ocr__Provider=Gemini
# UniFlow__Ocr__Provider=Stub
# AZURE_DOCUMENT_INTELLIGENCE_KEY=
# UniFlow__Ocr__Azure__Endpoint=https://your-resource.cognitiveservices.azure.com/

# =============================================================================
# Mobile (.NET MAUI) — set on dev machine, not in API container
# =============================================================================
# Android emulator + Docker API:
UNIFLOW_API_BASE_URL=http://10.0.2.2:5000/
# Android emulator + dotnet run (LocalDB):
# UNIFLOW_API_BASE_URL=http://10.0.2.2:5087/

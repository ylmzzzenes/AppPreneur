# Copy to .env and adjust for local Docker Compose (do not commit .env)

# --- PostgreSQL (docker compose postgres service) ---
POSTGRES_DB=uniflow
POSTGRES_USER=uniflow
POSTGRES_PASSWORD=uniflow_dev_password

DATABASE_PROVIDER=PostgreSql
CONNECTION_STRING=Host=postgres;Port=5432;Database=uniflow;Username=uniflow;Password=uniflow_dev_password

# Required for API startup (min 32 characters)
JWT_KEY=dev-jwt-secret-change-me-32chars-min

# --- AI provider (ASP.NET Core: Ai__* → Ai:* section) ---
# Provider: Gemini | OpenAiCompatible | Fake
# Fake = keyless demo (Development/Testing only; blocked in Production)
Ai__Provider=Gemini
Ai__ApiKey=
Ai__BaseUrl=https://api.openai.com/v1
Ai__Model=gemini-2.5-flash
Ai__TimeoutSeconds=30
Ai__RetryCount=2
Ai__EnableFallback=true
# Opsiyonel: varsayılan chat system prompt'u override et (boş = embedded Sarkastik Dahi)
# Ai__ChatSystemPrompt=Sen yardımcı bir asistansın...

# Optional alternate env keys — applied when Ai__ApiKey / Ai:ApiKey is empty:
# AI_API_KEY=your-key
# GEMINI_API_KEY=your-google-ai-studio-key   # legacy; Google AI Studio keys start with AIzaSy

# --- OpenRouter example (uncomment and set Ai__Provider=OpenAiCompatible) ---
# Ai__Provider=OpenAiCompatible
# Ai__BaseUrl=https://openrouter.ai/api/v1
# Ai__Model=meta-llama/llama-3.2-3b-instruct:free
# Ai__ApiKey=your-openrouter-key

# --- Groq example (uncomment and set Ai__Provider=OpenAiCompatible) ---
# Ai__Provider=OpenAiCompatible
# Ai__BaseUrl=https://api.groq.com/openai/v1
# Ai__Model=llama-3.1-8b-instant
# Ai__ApiKey=your-groq-key

# --- Fake provider (keyless local demo — dotnet run user-secrets or set here for Docker) ---
# Ai__Provider=Fake
# Ai__Model=fake-model

# Mobile MAUI — set when running on emulator/device (see README)
# Android emulator + Docker API: http://10.0.2.2:5000/
# Android emulator + dotnet run: http://10.0.2.2:5087/
UNIFLOW_API_BASE_URL=http://10.0.2.2:5000/

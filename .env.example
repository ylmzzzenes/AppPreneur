# Copy to .env and adjust for local Docker Compose (do not commit .env)
POSTGRES_DB=uniflow
POSTGRES_USER=uniflow
POSTGRES_PASSWORD=uniflow_dev_password

DATABASE_PROVIDER=PostgreSql
CONNECTION_STRING=Host=postgres;Port=5432;Database=uniflow;Username=uniflow;Password=uniflow_dev_password

# Required for API startup (min 32 characters)
JWT_KEY=dev-jwt-secret-change-me-32chars-min

# Optional — heuristic syllabus parsing works without this in Development
GEMINI_API_KEY=

# Mobile MAUI — set when running on emulator/device (see README)
# Android emulator: http://10.0.2.2:5000/
# Local dotnet run: http://10.0.2.2:5087/
UNIFLOW_API_BASE_URL=http://10.0.2.2:5000/

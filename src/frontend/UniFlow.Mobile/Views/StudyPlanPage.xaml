<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="UniFlow.Mobile.Views.StudyPlanPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:UniFlow.Mobile.Models"
    xmlns:vm="clr-namespace:UniFlow.Mobile.ViewModels"
    x:DataType="vm:StudyPlanViewModel"
    Style="{StaticResource UniFlowPage}"
    Title="Çalışma Planı">
    <ScrollView Padding="20,16">
        <VerticalStackLayout Spacing="16">
            <VerticalStackLayout Spacing="4">
                <Label Style="{StaticResource UniFlowPageTitle}" Text="AI çalışma planı" />
                <Label Style="{StaticResource UniFlowPageSubtitle}" Text="Hedeflerine göre kişisel plan oluştur." />
            </VerticalStackLayout>

            <Border Style="{StaticResource UniFlowCard}">
                <VerticalStackLayout Spacing="12">
                    <Label Style="{StaticResource UniFlowMeta}" Text="Gün sayısı" />
                    <Border Style="{StaticResource UniFlowFilterShell}">
                        <Picker ItemsSource="{Binding DayOptions}" SelectedItem="{Binding SelectedDays}" />
                    </Border>

                    <Label Style="{StaticResource UniFlowMeta}" Text="Ders (opsiyonel)" />
                    <Border Style="{StaticResource UniFlowFilterShell}">
                        <Picker
                            ItemsSource="{Binding Courses}"
                            ItemDisplayBinding="{Binding Title}"
                            SelectedItem="{Binding SelectedCourse}"
                            Title="Tüm dersler" />
                    </Border>

                    <Entry Placeholder="Odak (ör. vize hazırlığı)" Text="{Binding FocusText}" />

                    <Button
                        Style="{StaticResource UniFlowPrimaryButton}"
                        Command="{Binding GenerateCommand}"
                        Text="Plan oluştur" />
                </VerticalStackLayout>
            </Border>

            <ActivityIndicator HorizontalOptions="Center" IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}" />

            <Label
                IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}"
                Text="{Binding ErrorMessage}"
                TextColor="{StaticResource Danger}" />

            <VerticalStackLayout IsVisible="{Binding HasPlan}" Spacing="8">
                <Label Style="{StaticResource UniFlowSectionTitle}" Text="{Binding PlanTitle}" />
                <Label Style="{StaticResource UniFlowPageSubtitle}" Text="{Binding PlanSummary}" />
            </VerticalStackLayout>

            <CollectionView IsVisible="{Binding HasPlan}" ItemsSource="{Binding PlanDays}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:StudyPlanDayResponseDto">
                        <Border Margin="0,0,0,12" Style="{StaticResource UniFlowCard}">
                            <VerticalStackLayout Spacing="8">
                                <Label Style="{StaticResource UniFlowCardTitle}" Text="{Binding Date}" />
                                <Label Style="{StaticResource UniFlowMeta}" Text="{Binding Focus}" />
                                <CollectionView ItemsSource="{Binding Tasks}">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate x:DataType="models:StudyPlanTaskResponseDto">
                                            <Label Style="{StaticResource UniFlowMeta}" Text="{Binding Title, StringFormat='• {0}'}" />
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                                <Label
                                    FontSize="12"
                                    Text="{Binding Tip, StringFormat='💡 {0}'}"
                                    TextColor="{AppThemeBinding Light={StaticResource IndigoBrand}, Dark={StaticResource IndigoBrandDark}}" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

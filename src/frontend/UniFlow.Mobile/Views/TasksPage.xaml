<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="UniFlow.Mobile.Views.TasksPage"
    x:Name="TasksPageRoot"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:UniFlow.Mobile.Models"
    xmlns:vm="clr-namespace:UniFlow.Mobile.ViewModels"
    x:DataType="vm:TasksViewModel"
    Title="Görevler">
    <Grid RowDefinitions="Auto,Auto,Auto,*">
        <Button
            Grid.Row="0"
            Margin="16,12,16,0"
            Command="{Binding AddTaskCommand}"
            Text="+ Yeni görev" />

        <Grid
            Grid.Row="1"
            Margin="16,8"
            ColumnDefinitions="*,*"
            ColumnSpacing="8">
            <Picker
                Grid.Column="0"
                ItemsSource="{Binding RangeFilters}"
                SelectedItem="{Binding SelectedRange}" />
            <Picker
                Grid.Column="1"
                ItemsSource="{Binding StatusFilters}"
                SelectedItem="{Binding SelectedStatusFilter}" />
        </Grid>

        <Picker
            Grid.Row="2"
            Margin="16,0,16,8"
            ItemsSource="{Binding Courses}"
            ItemDisplayBinding="{Binding Title}"
            SelectedItem="{Binding SelectedCourse}"
            Title="Ders filtresi (opsiyonel)" />

        <RefreshView
            Grid.Row="3"
            Command="{Binding LoadCommand}"
            IsRefreshing="{Binding IsLoading, Mode=OneWay}">
            <CollectionView ItemsSource="{Binding Tasks}" Margin="16,0">
                <CollectionView.EmptyView>
                    <Label
                        HorizontalTextAlignment="Center"
                        Margin="0,40"
                        Text="{Binding StatusMessage, TargetNullValue='Görev bulunamadı.'}"
                        TextColor="{AppThemeBinding Light={StaticResource SlateSubtitle},
                                                    Dark={StaticResource SlateSubtitleDark}}" />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:TaskItemResponseDto">
                        <Border
                            Margin="0,0,0,10"
                            Padding="14"
                            Stroke="#E0E7FF"
                            StrokeShape="RoundRectangle 12">
                            <VerticalStackLayout Spacing="6">
                                <Label FontAttributes="Bold" Text="{Binding Title}" />
                                <Label FontSize="13" Text="{Binding CourseCode, StringFormat='Ders: {0}'}" />
                                <Label FontSize="13" Text="{Binding DueDate, StringFormat='Son tarih: {0:d}'}" />
                                <Label FontSize="13" Text="{Binding Status, StringFormat='Durum: {0}'}" />
                                <HorizontalStackLayout Spacing="8">
                                    <Button
                                        Command="{Binding Source={x:Reference TasksPageRoot}, Path=BindingContext.EditTaskCommand}"
                                        CommandParameter="{Binding .}"
                                        FontSize="12"
                                        Text="Düzenle" />
                                    <Button
                                        Command="{Binding Source={x:Reference TasksPageRoot}, Path=BindingContext.ChangeStatusCommand}"
                                        CommandParameter="{Binding .}"
                                        FontSize="12"
                                        Text="Durum" />
                                    <Button
                                        BackgroundColor="Transparent"
                                        Command="{Binding Source={x:Reference TasksPageRoot}, Path=BindingContext.DeleteTaskCommand}"
                                        CommandParameter="{Binding .}"
                                        FontSize="12"
                                        Text="Sil"
                                        TextColor="#C62828" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>

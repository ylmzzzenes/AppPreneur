<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="UniFlow.Mobile.Views.TasksPage"
    x:Name="TasksPageRoot"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:UniFlow.Mobile.Models"
    xmlns:vm="clr-namespace:UniFlow.Mobile.ViewModels"
    x:DataType="vm:TasksViewModel"
    Style="{StaticResource UniFlowPage}"
    Title="">
    <Grid RowDefinitions="Auto,Auto,*" Padding="20,16,20,8">
        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
            <VerticalStackLayout Grid.Column="0" Spacing="4">
                <Label Style="{StaticResource UniFlowPageTitle}" Text="Görevler" />
                <Label Style="{StaticResource UniFlowPageSubtitle}" Text="Filtrele, düzenle ve durumu güncelle." />
            </VerticalStackLayout>
            <Button
                Grid.Column="1"
                BackgroundColor="{AppThemeBinding Light=#EEF2FF, Dark=#312E81}"
                Command="{Binding AddTaskCommand}"
                CornerRadius="22"
                FontSize="22"
                HeightRequest="44"
                Text="＋"
                TextColor="{AppThemeBinding Light={StaticResource IndigoBrand}, Dark={StaticResource IndigoBrandDark}}"
                VerticalOptions="Center"
                WidthRequest="44" />
        </Grid>

        <!-- Filters -->
        <VerticalStackLayout Grid.Row="1" Spacing="10" Margin="0,0,0,12">
            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Border Grid.Column="0" Style="{StaticResource UniFlowFilterShell}">
                    <Picker
                        Style="{StaticResource UniFlowFilterPicker}"
                        ItemsSource="{Binding RangeFilters}"
                        SelectedItem="{Binding SelectedRange}"
                        Title="Zaman" />
                </Border>
                <Border Grid.Column="1" Style="{StaticResource UniFlowFilterShell}">
                    <Picker
                        Style="{StaticResource UniFlowFilterPicker}"
                        ItemsSource="{Binding StatusFilters}"
                        SelectedItem="{Binding SelectedStatusFilter}"
                        Title="Durum" />
                </Border>
            </Grid>
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <Border Grid.Column="0" Style="{StaticResource UniFlowFilterShell}">
                    <Picker
                        Style="{StaticResource UniFlowFilterPicker}"
                        ItemsSource="{Binding Courses}"
                        ItemDisplayBinding="{Binding Title}"
                        SelectedItem="{Binding SelectedCourse}"
                        Title="Ders filtresi" />
                </Border>
                <Button
                    Grid.Column="1"
                    Style="{StaticResource UniFlowGhostButton}"
                    Command="{Binding ClearCourseFilterCommand}"
                    IsVisible="{Binding SelectedCourse, Converter={StaticResource IsNotNullConverter}}"
                    Text="Temizle"
                    VerticalOptions="Center" />
            </Grid>
        </VerticalStackLayout>

        <RefreshView
            Grid.Row="2"
            Command="{Binding LoadCommand}"
            IsRefreshing="{Binding IsLoading, Mode=OneWay}">
            <CollectionView ItemsSource="{Binding Tasks}">
                <CollectionView.EmptyView>
                    <Border
                        Margin="0,32,0,0"
                        Padding="24,32"
                        BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#1F2937}"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 16">
                        <VerticalStackLayout Spacing="12">
                            <Label FontSize="36" HorizontalTextAlignment="Center" Text="📋" />
                            <Label
                                Style="{StaticResource UniFlowEmptyText}"
                                Text="{Binding StatusMessage, TargetNullValue='Görev bulunamadı. Yeni görev ekleyerek başla.'}" />
                            <Button
                                Style="{StaticResource UniFlowPrimaryButton}"
                                Command="{Binding AddTaskCommand}"
                                HorizontalOptions="Center"
                                Text="İlk görevi ekle" />
                        </VerticalStackLayout>
                    </Border>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:TaskItemResponseDto">
                        <Border Margin="0,0,0,12" Style="{StaticResource UniFlowCard}">
                            <VerticalStackLayout Spacing="10">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <Label
                                        Grid.Column="0"
                                        Style="{StaticResource UniFlowCardTitle}"
                                        Text="{Binding Title}" />
                                    <Border
                                        Grid.Column="1"
                                        BackgroundColor="{Binding Status, Converter={StaticResource TaskStatusBadgeBg}}"
                                        Style="{StaticResource UniFlowStatusBadge}">
                                        <Label
                                            FontFamily="OpenSansSemibold"
                                            FontSize="11"
                                            Text="{Binding Status, Converter={StaticResource TaskStatusToLabel}}"
                                            TextColor="{Binding Status, Converter={StaticResource TaskStatusBadgeText}}" />
                                    </Border>
                                </Grid>
                                <HorizontalStackLayout Spacing="14">
                                    <Label Style="{StaticResource UniFlowMeta}" Text="{Binding CourseCode, StringFormat='📚 {0}'}" />
                                    <Label Style="{StaticResource UniFlowMeta}" Text="{Binding DueDate, StringFormat='📅 {0:d}'}" />
                                </HorizontalStackLayout>
                                <BoxView
                                    HeightRequest="1"
                                    Color="{AppThemeBinding Light={StaticResource CardStrokeLight}, Dark={StaticResource CardStrokeDark}}" />
                                <Grid ColumnDefinitions="*,*,Auto" ColumnSpacing="6">
                                    <Button
                                        Grid.Column="0"
                                        Style="{StaticResource UniFlowChipButton}"
                                        Command="{Binding Source={x:Reference TasksPageRoot}, Path=BindingContext.EditTaskCommand}"
                                        CommandParameter="{Binding .}"
                                        Text="Düzenle" />
                                    <Button
                                        Grid.Column="1"
                                        Style="{StaticResource UniFlowSecondaryButton}"
                                        Command="{Binding Source={x:Reference TasksPageRoot}, Path=BindingContext.ChangeStatusCommand}"
                                        CommandParameter="{Binding .}"
                                        FontSize="12"
                                        Padding="8,8"
                                        Text="Durum" />
                                    <Button
                                        Grid.Column="2"
                                        Style="{StaticResource UniFlowDangerButton}"
                                        Command="{Binding Source={x:Reference TasksPageRoot}, Path=BindingContext.DeleteTaskCommand}"
                                        CommandParameter="{Binding .}"
                                        Text="Sil" />
                                </Grid>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>

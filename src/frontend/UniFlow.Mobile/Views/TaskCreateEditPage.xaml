<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="UniFlow.Mobile.Views.TaskCreateEditPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:UniFlow.Mobile.Models"
    xmlns:vm="clr-namespace:UniFlow.Mobile.ViewModels"
    x:DataType="vm:TaskCreateEditViewModel"
    Title="Görev">
    <ScrollView>
        <VerticalStackLayout Padding="24,16" Spacing="14">
            <Picker
                ItemDisplayBinding="{Binding Title}"
                ItemsSource="{Binding Courses}"
                SelectedItem="{Binding SelectedCourse}"
                Title="Ders" />
            <Entry Placeholder="Başlık" Text="{Binding Title}" />
            <Editor
                AutoSize="TextChanges"
                HeightRequest="80"
                Placeholder="Açıklama"
                Text="{Binding Description}" />
            <HorizontalStackLayout Spacing="8">
                <CheckBox IsChecked="{Binding HasDueDate}" />
                <Label Text="Son tarih var" VerticalOptions="Center" />
            </HorizontalStackLayout>
            <DatePicker Date="{Binding DueDate}" IsEnabled="{Binding HasDueDate}" />
            <Entry Keyboard="Numeric" Placeholder="Tahmini dakika" Text="{Binding EstimatedMinutes}" />
            <Entry Keyboard="Numeric" Placeholder="Öncelik (0-100)" Text="{Binding PriorityScore}" />
            <Picker
                ItemDisplayBinding="{Binding Label}"
                ItemsSource="{Binding StatusOptions}"
                SelectedItem="{Binding SelectedStatus}"
                Title="Durum" />
            <Label Text="{Binding StatusMessage}" TextColor="#C62828" />
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />
            <Button Command="{Binding SaveCommand}" Text="Kaydet" />
            <Button
                BackgroundColor="Transparent"
                Command="{Binding DeleteCommand}"
                IsVisible="{Binding IsEditMode}"
                Text="Sil"
                TextColor="#C62828" />
            <Button
                BackgroundColor="Transparent"
                Command="{Binding CancelCommand}"
                Text="İptal" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

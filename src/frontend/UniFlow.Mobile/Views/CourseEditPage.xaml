<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="UniFlow.Mobile.Views.CourseEditPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:UniFlow.Mobile.ViewModels"
    x:DataType="vm:CourseEditViewModel"
    Title="Ders">
    <ScrollView>
        <VerticalStackLayout Padding="24,16" Spacing="14">
            <Entry Placeholder="Ders kodu" Text="{Binding Code}" />
            <Entry Placeholder="Başlık" Text="{Binding Title}" />
            <Editor
                AutoSize="TextChanges"
                HeightRequest="80"
                Placeholder="Açıklama"
                Text="{Binding Description}" />
            <Entry Placeholder="Renk (#6366F1)" Text="{Binding Color}" />
            <Label Text="{Binding StatusMessage}" TextColor="#C62828" />
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />
            <Button Command="{Binding SaveCommand}" Text="Kaydet" />
            <Button
                BackgroundColor="Transparent"
                Command="{Binding CancelCommand}"
                Text="İptal" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="UniFlow.Mobile.Views.SyllabusPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:UniFlow.Mobile.ViewModels"
    x:DataType="vm:SyllabusViewModel"
    Title="Müfredat">
    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">
            <Label
                FontAttributes="Bold"
                FontSize="18"
                Text="Müfredattan görev çıkar" />
            <Label Opacity="0.85" Text="Ders bilgilerini gir; fotoğrafı galeriden seç veya kamerayla çek." />
            <Entry Placeholder="Ders kodu (örn. CS101)" Text="{Binding CourseCode}" />
            <Entry Placeholder="Ders adı" Text="{Binding CourseTitle}" />
            <Label FontAttributes="Bold" Text="Seçilen dosya" />
            <Label Text="{Binding PickedFileLabel}" />
            <HorizontalStackLayout Spacing="12">
                <Button Command="{Binding PickPhotoCommand}" Text="Galeriden seç" />
                <Button Command="{Binding CapturePhotoCommand}" Text="Kamerayla çek" />
            </HorizontalStackLayout>
            <Label Text="{Binding StatusMessage}" />
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />
            <Button Command="{Binding UploadCommand}" Text="Yükle ve işle" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

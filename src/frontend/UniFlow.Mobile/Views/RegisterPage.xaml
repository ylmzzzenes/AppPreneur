<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="UniFlow.Mobile.Views.RegisterPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:UniFlow.Mobile.ViewModels"
    x:DataType="vm:RegisterViewModel"
    Title="Kayıt"
    BackgroundColor="{AppThemeBinding Light={StaticResource SurfacePage},
                                      Dark={StaticResource SurfacePageDark}}">
    <ScrollView>
        <VerticalStackLayout
            Padding="30,32,30,36"
            Spacing="25"
            VerticalOptions="Start">
            <!-- Logo (giriş ile aynı) -->
            <Border
                Padding="0"
                HeightRequest="88"
                WidthRequest="88"
                Margin="0,0,0,4"
                HorizontalOptions="Center"
                StrokeThickness="0"
                BackgroundColor="{AppThemeBinding Light={StaticResource LoginHeroCircleLight},
                                                  Dark={StaticResource LoginHeroCircleDark}}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="28" />
                </Border.StrokeShape>
                <Label
                    FontFamily="OpenSansSemibold"
                    FontSize="36"
                    HorizontalOptions="Center"
                    Text="U"
                    TextColor="{AppThemeBinding Light={StaticResource IndigoBrand},
                                                Dark={StaticResource IndigoBrandDark}}"
                    VerticalOptions="Center" />
            </Border>

            <VerticalStackLayout Spacing="8">
                <Label
                    FontFamily="OpenSansSemibold"
                    FontSize="36"
                    HorizontalTextAlignment="Center"
                    Text="Yeni hesap"
                    TextColor="{AppThemeBinding Light={StaticResource IndigoBrand},
                                                Dark={StaticResource IndigoBrandDark}}" />
                <Label
                    FontFamily="OpenSansRegular"
                    FontSize="15"
                    HorizontalTextAlignment="Center"
                    LineHeight="1.35"
                    Opacity="0.95"
                    Text="Bilgilerini gir; giriş otomatik yapılır."
                    TextColor="{AppThemeBinding Light={StaticResource SlateSubtitle},
                                                Dark={StaticResource SlateSubtitleDark}}" />
            </VerticalStackLayout>

            <!-- Kullanıcı adı -->
            <Border
                Padding="12,10"
                BackgroundColor="{AppThemeBinding Light={StaticResource LoginFieldFillLight},
                                                  Dark={StaticResource FieldFillDark}}"
                Stroke="{AppThemeBinding Light={StaticResource LoginFieldStrokeIdle},
                                         Dark={StaticResource LoginFieldStrokeIdleDark}}"
                StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10" VerticalOptions="Center">
                    <Label
                        Grid.Column="0"
                        FontSize="18"
                        Text="👤"
                        TextColor="{AppThemeBinding Light={StaticResource LoginPlaceholder},
                                                    Dark={StaticResource SlateSubtitleDark}}"
                        VerticalOptions="Center"
                        VerticalTextAlignment="Center" />
                    <Entry
                        Grid.Column="1"
                        BackgroundColor="Transparent"
                        Focused="OnFieldFocused"
                        FontFamily="OpenSansRegular"
                        FontSize="15"
                        Placeholder="Kullanıcı adı"
                        PlaceholderColor="{AppThemeBinding Light={StaticResource LoginPlaceholder},
                                                          Dark={StaticResource SlateSubtitleDark}}"
                        Text="{Binding UserName}"
                        TextColor="{AppThemeBinding Light={StaticResource Black},
                                                   Dark={StaticResource White}}"
                        Unfocused="OnFieldUnfocused"
                        VerticalOptions="Center" />
                </Grid>
            </Border>

            <!-- E-posta -->
            <Border
                Padding="12,10"
                BackgroundColor="{AppThemeBinding Light={StaticResource LoginFieldFillLight},
                                                  Dark={StaticResource FieldFillDark}}"
                Stroke="{AppThemeBinding Light={StaticResource LoginFieldStrokeIdle},
                                         Dark={StaticResource LoginFieldStrokeIdleDark}}"
                StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10" VerticalOptions="Center">
                    <Label
                        Grid.Column="0"
                        FontSize="18"
                        Text="📧"
                        TextColor="{AppThemeBinding Light={StaticResource LoginPlaceholder},
                                                    Dark={StaticResource SlateSubtitleDark}}"
                        VerticalOptions="Center"
                        VerticalTextAlignment="Center" />
                    <Entry
                        Grid.Column="1"
                        BackgroundColor="Transparent"
                        Focused="OnFieldFocused"
                        FontFamily="OpenSansRegular"
                        FontSize="15"
                        Keyboard="Email"
                        Placeholder="E-posta"
                        PlaceholderColor="{AppThemeBinding Light={StaticResource LoginPlaceholder},
                                                          Dark={StaticResource SlateSubtitleDark}}"
                        Text="{Binding Email}"
                        TextColor="{AppThemeBinding Light={StaticResource Black},
                                                   Dark={StaticResource White}}"
                        Unfocused="OnFieldUnfocused"
                        VerticalOptions="Center" />
                </Grid>
            </Border>

            <!-- Şifre -->
            <Border
                Padding="12,10"
                BackgroundColor="{AppThemeBinding Light={StaticResource LoginFieldFillLight},
                                                  Dark={StaticResource FieldFillDark}}"
                Stroke="{AppThemeBinding Light={StaticResource LoginFieldStrokeIdle},
                                         Dark={StaticResource LoginFieldStrokeIdleDark}}"
                StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>
                <Grid
                    ColumnDefinitions="Auto,*,Auto"
                    ColumnSpacing="8"
                    VerticalOptions="Center">
                    <Label
                        Grid.Column="0"
                        FontSize="17"
                        Text="🔒"
                        TextColor="{AppThemeBinding Light={StaticResource LoginPlaceholder},
                                                    Dark={StaticResource SlateSubtitleDark}}"
                        VerticalOptions="Center"
                        VerticalTextAlignment="Center" />
                    <Entry
                        Grid.Column="1"
                        BackgroundColor="Transparent"
                        Focused="OnFieldFocused"
                        FontFamily="OpenSansRegular"
                        FontSize="15"
                        IsPassword="{Binding ObscurePassword}"
                        Placeholder="Şifre (en az 8 karakter)"
                        PlaceholderColor="{AppThemeBinding Light={StaticResource LoginPlaceholder},
                                                          Dark={StaticResource SlateSubtitleDark}}"
                        Text="{Binding Password}"
                        TextColor="{AppThemeBinding Light={StaticResource Black},
                                                   Dark={StaticResource White}}"
                        Unfocused="OnFieldUnfocused"
                        VerticalOptions="Center" />
                    <Label
                        Grid.Column="2"
                        FontSize="17"
                        HorizontalOptions="End"
                        HorizontalTextAlignment="Center"
                        MinimumHeightRequest="44"
                        MinimumWidthRequest="44"
                        Text="👁"
                        TextColor="{AppThemeBinding Light={StaticResource SlateSubtitle},
                                                    Dark={StaticResource SlateSubtitleDark}}"
                        VerticalOptions="Center"
                        VerticalTextAlignment="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding TogglePasswordVisibilityCommand}" />
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>
            </Border>

            <!-- Şifre tekrar -->
            <Border
                Padding="12,10"
                BackgroundColor="{AppThemeBinding Light={StaticResource LoginFieldFillLight},
                                                  Dark={StaticResource FieldFillDark}}"
                Stroke="{AppThemeBinding Light={StaticResource LoginFieldStrokeIdle},
                                         Dark={StaticResource LoginFieldStrokeIdleDark}}"
                StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>
                <Grid
                    ColumnDefinitions="Auto,*,Auto"
                    ColumnSpacing="8"
                    VerticalOptions="Center">
                    <Label
                        Grid.Column="0"
                        FontSize="17"
                        Text="🔒"
                        TextColor="{AppThemeBinding Light={StaticResource LoginPlaceholder},
                                                    Dark={StaticResource SlateSubtitleDark}}"
                        VerticalOptions="Center"
                        VerticalTextAlignment="Center" />
                    <Entry
                        Grid.Column="1"
                        BackgroundColor="Transparent"
                        Focused="OnFieldFocused"
                        FontFamily="OpenSansRegular"
                        FontSize="15"
                        IsPassword="{Binding ObscurePassword}"
                        Placeholder="Şifre tekrar"
                        PlaceholderColor="{AppThemeBinding Light={StaticResource LoginPlaceholder},
                                                          Dark={StaticResource SlateSubtitleDark}}"
                        Text="{Binding ConfirmPassword}"
                        TextColor="{AppThemeBinding Light={StaticResource Black},
                                                   Dark={StaticResource White}}"
                        Unfocused="OnFieldUnfocused"
                        VerticalOptions="Center" />
                    <Label
                        Grid.Column="2"
                        FontSize="17"
                        HorizontalOptions="End"
                        HorizontalTextAlignment="Center"
                        MinimumHeightRequest="44"
                        MinimumWidthRequest="44"
                        Text="👁"
                        TextColor="{AppThemeBinding Light={StaticResource SlateSubtitle},
                                                    Dark={StaticResource SlateSubtitleDark}}"
                        VerticalOptions="Center"
                        VerticalTextAlignment="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding TogglePasswordVisibilityCommand}" />
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>
            </Border>

            <Label
                Margin="0,-8,0,0"
                Text="{Binding StatusMessage}"
                TextColor="{AppThemeBinding Light=#C62828,
                                            Dark=#FF8A80}" />

            <ActivityIndicator
                Margin="0,-8,0,0"
                HorizontalOptions="Center"
                Color="{AppThemeBinding Light={StaticResource IndigoBrand},
                                         Dark={StaticResource IndigoBrandDark}}"
                IsRunning="{Binding IsBusy}"
                IsVisible="{Binding IsBusy}" />

            <VerticalStackLayout Spacing="14" Margin="0,6,0,0">
                <Button
                    BackgroundColor="{AppThemeBinding Light={StaticResource IndigoBrand},
                                                      Dark={StaticResource IndigoBrandDark}}"
                    BorderWidth="0"
                    Command="{Binding RegisterCommand}"
                    CornerRadius="12"
                    FontFamily="OpenSansSemibold"
                    FontSize="16"
                    HeightRequest="52"
                    Text="Kayıt ol"
                    TextColor="White">
                    <Button.Shadow>
                        <Shadow
                            Brush="#406366F1"
                            Opacity="0.42"
                            Radius="18"
                            Offset="0,8" />
                    </Button.Shadow>
                </Button>

                <Button
                    BackgroundColor="Transparent"
                    BorderColor="{AppThemeBinding Light={StaticResource IndigoBrand},
                                                  Dark={StaticResource IndigoBrandDark}}"
                    BorderWidth="1"
                    Command="{Binding GoBackCommand}"
                    CornerRadius="12"
                    FontFamily="OpenSansSemibold"
                    FontSize="15"
                    HeightRequest="48"
                    Text="Giriş yap"
                    TextColor="{AppThemeBinding Light={StaticResource IndigoBrand},
                                               Dark={StaticResource IndigoBrandDark}}" />
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

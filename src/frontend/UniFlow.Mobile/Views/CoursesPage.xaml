<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="UniFlow.Mobile.Views.CoursesPage"
    x:Name="CoursesPageRoot"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:UniFlow.Mobile.Models"
    xmlns:vm="clr-namespace:UniFlow.Mobile.ViewModels"
    x:DataType="vm:CoursesViewModel"
    Title="Dersler">
    <Grid RowDefinitions="Auto,*">
        <Button
            Grid.Row="0"
            Margin="16,12"
            Command="{Binding AddCourseCommand}"
            Text="+ Yeni ders" />

        <RefreshView
            Grid.Row="1"
            Command="{Binding LoadCommand}"
            IsRefreshing="{Binding IsLoading, Mode=OneWay}">
            <CollectionView ItemsSource="{Binding Courses}" Margin="16,0">
                <CollectionView.EmptyView>
                    <Label
                        HorizontalTextAlignment="Center"
                        Margin="0,40"
                        Text="Henüz ders yok. Yeni ders ekleyin."
                        TextColor="{AppThemeBinding Light={StaticResource SlateSubtitle},
                                                    Dark={StaticResource SlateSubtitleDark}}" />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:CourseResponseDto">
                        <Border
                            Margin="0,0,0,10"
                            Padding="14"
                            Stroke="#E0E7FF"
                            StrokeShape="RoundRectangle 12">
                            <VerticalStackLayout Spacing="6">
                                <Label FontAttributes="Bold" Text="{Binding Code}" />
                                <Label Text="{Binding Title}" />
                                <Label FontSize="12" Text="{Binding TaskCount, StringFormat='Görev: {0}'}" />
                                <Label FontSize="12" Text="{Binding ActiveTaskCount, StringFormat='Aktif: {0}'}" />
                                <HorizontalStackLayout Spacing="8">
                                    <Button
                                        Command="{Binding Source={x:Reference CoursesPageRoot}, Path=BindingContext.EditCourseCommand}"
                                        CommandParameter="{Binding .}"
                                        FontSize="12"
                                        Text="Düzenle" />
                                    <Button
                                        BackgroundColor="Transparent"
                                        Command="{Binding Source={x:Reference CoursesPageRoot}, Path=BindingContext.DeleteCourseCommand}"
                                        CommandParameter="{Binding .}"
                                        FontSize="12"
                                        Text="Sil"
                                        TextColor="#C62828" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <Label
            Grid.RowSpan="2"
            Margin="16"
            Text="{Binding StatusMessage}"
            TextColor="#C62828"
            VerticalOptions="End" />
    </Grid>
</ContentPage>

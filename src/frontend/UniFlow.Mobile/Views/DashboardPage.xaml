<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="UniFlow.Mobile.Views.DashboardPage"
    x:Name="DashboardPageRoot"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:UniFlow.Mobile.Models"
    xmlns:vm="clr-namespace:UniFlow.Mobile.ViewModels"
    x:DataType="vm:DashboardViewModel"
    Style="{StaticResource UniFlowPage}"
    Title="">
    <Grid>
        <Grid Padding="20,16,20,24" RowDefinitions="Auto,*">
            <!-- Header -->
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,16">
                <HorizontalStackLayout Grid.Column="0" Spacing="12" VerticalOptions="Center">
                    <Border Style="{StaticResource UniFlowAvatar}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToProfileCommand}" />
                        </Border.GestureRecognizers>
                        <Label
                            FontFamily="OpenSansSemibold"
                            FontSize="17"
                            HorizontalOptions="Center"
                            Text="{Binding UserInitial}"
                            TextColor="{AppThemeBinding Light={StaticResource IndigoBrand}, Dark={StaticResource IndigoBrandDark}}"
                            VerticalOptions="Center" />
                    </Border>
                    <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                        <Label Style="{StaticResource UniFlowPageTitle}" Text="Bugün" />
                        <Label
                            Style="{StaticResource UniFlowPageSubtitle}"
                            Text="Big 3 odak listesi ve günlük mesaj." />
                    </VerticalStackLayout>
                </HorizontalStackLayout>
                <Button
                    Grid.Column="1"
                    BackgroundColor="{AppThemeBinding Light=#EEF2FF, Dark=#312E81}"
                    Command="{Binding GoToCreateTaskCommand}"
                    CornerRadius="22"
                    FontSize="20"
                    HeightRequest="44"
                    Text="＋"
                    TextColor="{AppThemeBinding Light={StaticResource IndigoBrand}, Dark={StaticResource IndigoBrandDark}}"
                    WidthRequest="44" />
                <Button
                    Grid.Column="2"
                    Style="{StaticResource UniFlowGhostButton}"
                    Command="{Binding LogoutCommand}"
                    FontSize="20"
                    Text="⎋"
                    WidthRequest="44" />
            </Grid>

            <RefreshView
                Grid.Row="1"
                Command="{Binding LoadCommand}"
                IsRefreshing="{Binding IsLoading, Mode=OneWay}">
                <ScrollView>
                    <VerticalStackLayout Spacing="16">
                        <!-- Günlük mesaj -->
                        <Border Style="{StaticResource UniFlowAccentCard}">
                            <VerticalStackLayout Spacing="12">
                                <Label
                                    FontFamily="OpenSansSemibold"
                                    FontSize="14"
                                    Text="{Binding AiMood, StringFormat='Ruh hali · {0}'}"
                                    TextColor="{AppThemeBinding Light={StaticResource IndigoBrand}, Dark={StaticResource IndigoBrandDark}}" />
                                <Label
                                    FontFamily="OpenSansRegular"
                                    FontSize="15"
                                    LineBreakMode="WordWrap"
                                    Text="{Binding DailyMessage}"
                                    TextColor="{AppThemeBinding Light={StaticResource SlateHeader}, Dark={StaticResource White}}" />
                                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                                    <Border Style="{StaticResource UniFlowStatChip}">
                                        <Label
                                            FontSize="12"
                                            HorizontalTextAlignment="Center"
                                            Text="{Binding PendingTodayCount, StringFormat='Bekleyen {0}'}"
                                            TextColor="{AppThemeBinding Light={StaticResource SlateHeader}, Dark={StaticResource White}}" />
                                    </Border>
                                    <Border Style="{StaticResource UniFlowStatChip}">
                                        <Label
                                            FontSize="12"
                                            HorizontalTextAlignment="Center"
                                            Text="{Binding CompletedTodayCount, StringFormat='Tamam {0}'}"
                                            TextColor="{StaticResource Success}" />
                                    </Border>
                                    <Border Style="{StaticResource UniFlowStatChip}">
                                        <Label
                                            FontSize="12"
                                            HorizontalTextAlignment="Center"
                                            Text="{Binding OverdueTasksCount, StringFormat='Geciken {0}'}"
                                            TextColor="{StaticResource Warning}" />
                                    </Border>
                                </Grid>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Haftalık özet -->
                        <Border Style="{StaticResource UniFlowCard}">
                            <VerticalStackLayout Spacing="10">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <Label
                                        Grid.Column="0"
                                        Style="{StaticResource UniFlowSectionTitle}"
                                        Text="Haftalık özet"
                                        VerticalOptions="Center" />
                                    <Button
                                        Grid.Column="1"
                                        Style="{StaticResource UniFlowGhostButton}"
                                        Command="{Binding LoadWeeklySummaryCommand}"
                                        FontSize="13"
                                        Text="Yenile"
                                        VerticalOptions="Center" />
                                </Grid>
                                <Label
                                    FontFamily="OpenSansRegular"
                                    FontSize="14"
                                    IsVisible="{Binding HasWeeklySummary}"
                                    LineBreakMode="WordWrap"
                                    Text="{Binding WeeklySummaryText}"
                                    TextColor="{AppThemeBinding Light={StaticResource SlateHeader}, Dark={StaticResource White}}" />
                                <Label
                                    Style="{StaticResource UniFlowMeta}"
                                    IsVisible="{Binding HasWeeklySummary}"
                                    Text="{Binding WeeklyNextFocus, StringFormat='Odak: {0}'}" />
                                <Label
                                    FontSize="13"
                                    IsVisible="{Binding ShowWeeklyPlaceholder}"
                                    Text="Haftalık özet henüz yüklenmedi. Yenile'ye dokunun."
                                    TextColor="{AppThemeBinding Light={StaticResource SlateSubtitle}, Dark={StaticResource SlateSubtitleDark}}" />
                                <Label
                                    FontSize="13"
                                    IsVisible="{Binding HasWeeklySummaryError}"
                                    Text="{Binding WeeklySummaryError}"
                                    TextColor="{StaticResource Warning}" />
                                <ActivityIndicator
                                    HorizontalOptions="Start"
                                    IsRunning="{Binding IsWeeklyLoading}"
                                    IsVisible="{Binding IsWeeklyLoading}" />
                            </VerticalStackLayout>
                        </Border>

                        <Button
                            Style="{StaticResource UniFlowPrimaryButton}"
                            Command="{Binding GoToStudyPlanCommand}"
                            Text="Çalışma planı oluştur" />

                        <!-- Big 3 -->
                        <Label Style="{StaticResource UniFlowSectionTitle}" Text="Big 3" />

                        <CollectionView ItemsSource="{Binding BigThreeTasks}">
                            <CollectionView.EmptyView>
                                <Border
                                    Margin="0,4,0,0"
                                    Padding="24,28"
                                    BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#1F2937}"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 16">
                                    <VerticalStackLayout Spacing="14">
                                        <Label
                                            FontSize="32"
                                            HorizontalTextAlignment="Center"
                                            Text="✨" />
                                        <Label
                                            Style="{StaticResource UniFlowEmptyText}"
                                            Text="Bugün için öncelikli görev yok." />
                                        <Button
                                            Style="{StaticResource UniFlowPrimaryButton}"
                                            Command="{Binding GoToSyllabusCommand}"
                                            HorizontalOptions="Center"
                                            Text="Müfredat tara" />
                                    </VerticalStackLayout>
                                </Border>
                            </CollectionView.EmptyView>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:DashboardTaskItemDto">
                                    <Border Margin="0,0,0,12" Style="{StaticResource UniFlowCard}">
                                        <VerticalStackLayout Spacing="10">
                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                <Label
                                                    Grid.Column="0"
                                                    Style="{StaticResource UniFlowCardTitle}"
                                                    Text="{Binding Title}" />
                                                <Border
                                                    Grid.Column="1"
                                                    BackgroundColor="{Binding Status, Converter={StaticResource TaskStatusBadgeBg}}"
                                                    Style="{StaticResource UniFlowStatusBadge}"
                                                    VerticalOptions="Start">
                                                    <Label
                                                        FontFamily="OpenSansSemibold"
                                                        FontSize="11"
                                                        Text="{Binding Status, Converter={StaticResource TaskStatusToLabel}}"
                                                        TextColor="{Binding Status, Converter={StaticResource TaskStatusBadgeText}}" />
                                                </Border>
                                            </Grid>
                                            <HorizontalStackLayout Spacing="16">
                                                <Label Style="{StaticResource UniFlowMeta}" Text="{Binding CourseCode, StringFormat='📚 {0}'}" />
                                                <Label Style="{StaticResource UniFlowMeta}" Text="{Binding DueDate, StringFormat='📅 {0:d}'}" />
                                                <Label Style="{StaticResource UniFlowMeta}" Text="{Binding PriorityScore, StringFormat='⚡ {0}'}" />
                                            </HorizontalStackLayout>
                                            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="6">
                                                <Button
                                                    Grid.Column="0"
                                                    Style="{StaticResource UniFlowChipButton}"
                                                    Command="{Binding Source={x:Reference DashboardPageRoot}, Path=BindingContext.MarkTaskDoneCommand}"
                                                    CommandParameter="{Binding .}"
                                                    Text="Tamam" />
                                                <Button
                                                    Grid.Column="1"
                                                    Style="{StaticResource UniFlowSecondaryButton}"
                                                    Command="{Binding Source={x:Reference DashboardPageRoot}, Path=BindingContext.MarkTaskPendingCommand}"
                                                    CommandParameter="{Binding .}"
                                                    FontSize="12"
                                                    Padding="8,8"
                                                    Text="Bekliyor" />
                                                <Button
                                                    Grid.Column="2"
                                                    BackgroundColor="Transparent"
                                                    BorderColor="{StaticResource Warning}"
                                                    BorderWidth="1"
                                                    Command="{Binding Source={x:Reference DashboardPageRoot}, Path=BindingContext.MarkTaskMissedCommand}"
                                                    CommandParameter="{Binding .}"
                                                    CornerRadius="20"
                                                    FontFamily="OpenSansSemibold"
                                                    FontSize="12"
                                                    Padding="8,8"
                                                    Text="Kaçırıldı"
                                                    TextColor="{StaticResource Warning}" />
                                            </Grid>
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </ScrollView>
            </RefreshView>
        </Grid>

        <Grid
            BackgroundColor="#80000000"
            InputTransparent="False"
            IsVisible="{Binding ShowInitialLoading}"
            ZIndex="50">
            <VerticalStackLayout HorizontalOptions="Center" Spacing="12" VerticalOptions="Center">
                <ActivityIndicator
                    Color="{AppThemeBinding Light={StaticResource IndigoBrand}, Dark={StaticResource IndigoBrandDark}}"
                    IsRunning="True" />
                <Label
                    FontFamily="OpenSansRegular"
                    FontSize="14"
                    Text="Bugün yükleniyor…"
                    TextColor="White" />
            </VerticalStackLayout>
        </Grid>

        <Border
            x:Name="SnackbarHost"
            Margin="16,8"
            Padding="14,12"
            HorizontalOptions="Fill"
            IsVisible="False"
            Stroke="#FCA5A5"
            TranslationY="-180"
            VerticalOptions="Start"
            ZIndex="100"
            BackgroundColor="{AppThemeBinding Light={StaticResource SnackErrorBgLight}, Dark={StaticResource SnackErrorBgDark}}">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12" />
            </Border.StrokeShape>
            <Label
                x:Name="SnackbarLabel"
                FontFamily="OpenSansRegular"
                FontSize="14"
                LineBreakMode="WordWrap"
                TextColor="{AppThemeBinding Light={StaticResource SnackErrorTextLight}, Dark={StaticResource SnackErrorTextDark}}" />
        </Border>
    </Grid>
</ContentPage>

<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="UniFlow.Mobile.Views.DashboardPage"
    x:Name="DashboardPageRoot"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:UniFlow.Mobile.Models"
    xmlns:vm="clr-namespace:UniFlow.Mobile.ViewModels"
    x:DataType="vm:DashboardViewModel"
    Title="">
    <Grid>
        <Grid Padding="20,12,20,16" RowDefinitions="Auto,*">
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,14">
                <HorizontalStackLayout Grid.Column="0" Spacing="12" VerticalOptions="Center">
                    <Border
                        HeightRequest="44"
                        WidthRequest="44"
                        BackgroundColor="{AppThemeBinding Light=#206366F1,
                                                          Dark=#40818CF8}"
                        StrokeThickness="0"
                        VerticalOptions="Center">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToProfileCommand}" />
                        </Border.GestureRecognizers>
                        <Border.StrokeShape>
                            <Ellipse />
                        </Border.StrokeShape>
                        <Label
                            FontFamily="OpenSansSemibold"
                            FontSize="18"
                            HorizontalOptions="Center"
                            Text="{Binding UserInitial}"
                            TextColor="{AppThemeBinding Light={StaticResource IndigoBrand},
                                                        Dark={StaticResource IndigoBrandDark}}"
                            VerticalOptions="Center" />
                    </Border>
                    <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                        <Label
                            FontFamily="OpenSansSemibold"
                            FontSize="28"
                            Text="Bugün"
                            TextColor="{AppThemeBinding Light={StaticResource SlateHeader},
                                                        Dark={StaticResource White}}" />
                        <Label
                            FontFamily="OpenSansRegular"
                            FontSize="13"
                            Text="Big 3 odak listesi ve günlük mesaj."
                            TextColor="{AppThemeBinding Light={StaticResource SlateSubtitle},
                                                        Dark={StaticResource SlateSubtitleDark}}" />
                    </VerticalStackLayout>
                </HorizontalStackLayout>
                <Button
                    Grid.Column="1"
                    BackgroundColor="Transparent"
                    Command="{Binding GoToCreateTaskCommand}"
                    FontSize="22"
                    Text="➕"
                    TextColor="{AppThemeBinding Light={StaticResource IndigoBrand},
                                                Dark={StaticResource IndigoBrandDark}}" />
                <Button
                    Grid.Column="2"
                    BackgroundColor="Transparent"
                    Command="{Binding LogoutCommand}"
                    FontSize="22"
                    Text="🚪"
                    TextColor="{AppThemeBinding Light={StaticResource SlateSubtitle},
                                                Dark={StaticResource SlateSubtitleDark}}" />
            </Grid>

            <RefreshView
                Grid.Row="1"
                Command="{Binding LoadCommand}"
                IsRefreshing="{Binding IsLoading, Mode=OneWay}">
                <ScrollView>
                    <VerticalStackLayout Spacing="14">
                        <Border
                            Padding="16"
                            BackgroundColor="{AppThemeBinding Light=#F5F3FF,
                                                              Dark=#1E1B4B}"
                            Stroke="#C7D2FE"
                            StrokeShape="RoundRectangle 12">
                            <VerticalStackLayout Spacing="8">
                                <Label
                                    FontFamily="OpenSansSemibold"
                                    FontSize="15"
                                    Text="{Binding AiMood, StringFormat='Ruh hali: {0}'}"
                                    TextColor="{AppThemeBinding Light={StaticResource IndigoBrand},
                                                                Dark={StaticResource IndigoBrandDark}}" />
                                <Label
                                    FontFamily="OpenSansRegular"
                                    FontSize="15"
                                    LineBreakMode="WordWrap"
                                    Text="{Binding DailyMessage}"
                                    TextColor="{AppThemeBinding Light={StaticResource SlateHeader},
                                                                Dark={StaticResource White}}" />
                                <HorizontalStackLayout Spacing="12">
                                    <Label FontSize="12" Text="{Binding PendingTodayCount, StringFormat='Bekleyen: {0}'}" />
                                    <Label FontSize="12" Text="{Binding CompletedTodayCount, StringFormat='Tamamlanan: {0}'}" />
                                    <Label FontSize="12" Text="{Binding OverdueTasksCount, StringFormat='Geciken: {0}'}" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Border>

                        <Label
                            FontFamily="OpenSansSemibold"
                            FontSize="18"
                            Text="Big 3"
                            TextColor="{AppThemeBinding Light={StaticResource SlateHeader},
                                                        Dark={StaticResource White}}" />

                        <CollectionView ItemsSource="{Binding BigThreeTasks}">
                            <CollectionView.EmptyView>
                                <VerticalStackLayout Padding="12,24" Spacing="12">
                                    <Label
                                        HorizontalTextAlignment="Center"
                                        Text="Bugün için öncelikli görev yok."
                                        TextColor="{AppThemeBinding Light={StaticResource SlateSubtitle},
                                                                    Dark={StaticResource SlateSubtitleDark}}" />
                                    <Button
                                        BackgroundColor="{AppThemeBinding Light={StaticResource IndigoBrand},
                                                                          Dark={StaticResource IndigoBrandDark}}"
                                        Command="{Binding GoToSyllabusCommand}"
                                        CornerRadius="12"
                                        HorizontalOptions="Center"
                                        Text="Müfredat tara"
                                        TextColor="White" />
                                </VerticalStackLayout>
                            </CollectionView.EmptyView>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:DashboardTaskItemDto">
                                    <Border
                                        Margin="0,0,0,10"
                                        Padding="14"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource White},
                                                                          Dark={StaticResource FieldFillDark}}"
                                        Stroke="#E0E7FF"
                                        StrokeShape="RoundRectangle 12">
                                        <VerticalStackLayout Spacing="6">
                                            <Label
                                                FontAttributes="Bold"
                                                Text="{Binding Title}"
                                                TextColor="{AppThemeBinding Light={StaticResource SlateHeader},
                                                                            Dark={StaticResource White}}" />
                                            <Label FontSize="13" Text="{Binding CourseCode, StringFormat='Ders: {0}'}" />
                                            <Label FontSize="13" Text="{Binding DueDate, StringFormat='Son tarih: {0:d}'}" />
                                            <Label FontSize="13" Text="{Binding PriorityScore, StringFormat='Öncelik: {0}'}" />
                                            <Label FontSize="13" Text="{Binding Status, StringFormat='Durum: {0}'}" />
                                            <HorizontalStackLayout Spacing="8">
                                                <Button
                                                    BackgroundColor="{AppThemeBinding Light={StaticResource IndigoBrand},
                                                                                      Dark={StaticResource IndigoBrandDark}}"
                                                    Command="{Binding Source={x:Reference DashboardPageRoot}, Path=BindingContext.MarkTaskDoneCommand}"
                                                    CommandParameter="{Binding .}"
                                                    CornerRadius="8"
                                                    FontSize="12"
                                                    Text="Tamamlandı"
                                                    TextColor="White" />
                                                <Button
                                                    BackgroundColor="Transparent"
                                                    BorderColor="{AppThemeBinding Light={StaticResource IndigoBrand},
                                                                                  Dark={StaticResource IndigoBrandDark}}"
                                                    BorderWidth="1"
                                                    Command="{Binding Source={x:Reference DashboardPageRoot}, Path=BindingContext.MarkTaskPendingCommand}"
                                                    CommandParameter="{Binding .}"
                                                    CornerRadius="8"
                                                    FontSize="12"
                                                    Text="Bekliyor"
                                                    TextColor="{AppThemeBinding Light={StaticResource IndigoBrand},
                                                                                Dark={StaticResource IndigoBrandDark}}" />
                                            </HorizontalStackLayout>
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </ScrollView>
            </RefreshView>
        </Grid>

        <Border
            x:Name="SnackbarHost"
            Margin="16,8"
            Padding="14,12"
            HorizontalOptions="Fill"
            IsVisible="False"
            Stroke="#FCA5A5"
            TranslationY="-180"
            VerticalOptions="Start"
            ZIndex="100"
            BackgroundColor="{AppThemeBinding Light={StaticResource SnackErrorBgLight},
                                               Dark={StaticResource SnackErrorBgDark}}">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12" />
            </Border.StrokeShape>
            <Label
                x:Name="SnackbarLabel"
                FontFamily="OpenSansRegular"
                FontSize="14"
                LineBreakMode="WordWrap"
                TextColor="{AppThemeBinding Light={StaticResource SnackErrorTextLight},
                                            Dark={StaticResource SnackErrorTextDark}}" />
        </Border>
    </Grid>
</ContentPage>

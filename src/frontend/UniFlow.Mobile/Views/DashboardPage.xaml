<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="UniFlow.Mobile.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:UniFlow.Mobile.Models"
    xmlns:vm="clr-namespace:UniFlow.Mobile.ViewModels"
    x:DataType="vm:DashboardViewModel"
    Title="">
    <Grid>
        <Grid Padding="20,12,20,16" RowDefinitions="Auto,*">
            <!-- Üst başlık -->
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,14">
                <HorizontalStackLayout Grid.Column="0" Spacing="12" VerticalOptions="Center">
                    <Border
                        HeightRequest="44"
                        WidthRequest="44"
                        Padding="0"
                        BackgroundColor="{AppThemeBinding Light=#206366F1,
                                                          Dark=#40818CF8}}"
                        StrokeThickness="0"
                        VerticalOptions="Center">
                        <Border.StrokeShape>
                            <Ellipse />
                        </Border.StrokeShape>
                        <Label
                            FontFamily="OpenSansSemibold"
                            FontSize="18"
                            HorizontalOptions="Center"
                            Text="{Binding UserInitial}"
                            TextColor="{AppThemeBinding Light={StaticResource IndigoBrand},
                                                        Dark={StaticResource IndigoBrandDark}}"
                            VerticalOptions="Center"
                            VerticalTextAlignment="Center" />
                    </Border>
                    <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                        <Label
                            FontFamily="OpenSansSemibold"
                            FontSize="28"
                            LineBreakMode="TailTruncation"
                            MaxLines="1"
                            Text="Görevler"
                            TextColor="{AppThemeBinding Light={StaticResource SlateHeader},
                                                        Dark={StaticResource White}}"
                            VerticalOptions="Center" />
                        <Label
                            FontFamily="OpenSansRegular"
                            FontSize="13"
                            LineBreakMode="WordWrap"
                            MaxLines="2"
                            Opacity="0.92"
                            Text="Bugün odaklanman gerekenler; süreci buradan yönet."
                            TextColor="{AppThemeBinding Light={StaticResource SlateSubtitle},
                                                        Dark={StaticResource SlateSubtitleDark}}" />
                    </VerticalStackLayout>
                </HorizontalStackLayout>
                <Button
                    Grid.Column="1"
                    Padding="10"
                    VerticalOptions="Center"
                    BackgroundColor="Transparent"
                    Command="{Binding LogoutCommand}"
                    FontSize="22"
                    SemanticProperties.Description="Çıkış"
                    Text="🚪"
                    TextColor="{AppThemeBinding Light={StaticResource SlateSubtitle},
                                                Dark={StaticResource SlateSubtitleDark}}" />
            </Grid>

            <RefreshView
                Grid.Row="1"
                Command="{Binding LoadCommand}"
                IsRefreshing="{Binding IsLoading, Mode=OneWay}">
                <CollectionView ItemsSource="{Binding Tasks}" VerticalOptions="Fill">
                    <CollectionView.EmptyView>
                        <VerticalStackLayout
                            Padding="12,48,12,48"
                            Spacing="16"
                            VerticalOptions="Center">
                            <!-- Boş liste betiği -->
                            <Border
                                Padding="0"
                                HeightRequest="120"
                                WidthRequest="120"
                                HorizontalOptions="Center"
                                BackgroundColor="{AppThemeBinding Light=#206366F1,
                                                                  Dark=#40818CF8}}"
                                StrokeThickness="0"
                                VerticalOptions="Center">
                                <Border.StrokeShape>
                                    <Ellipse />
                                </Border.StrokeShape>
                                <Label
                                    FontSize="52"
                                    HorizontalOptions="Center"
                                    HorizontalTextAlignment="Center"
                                    Text="📋"
                                    VerticalOptions="Center"
                                    VerticalTextAlignment="Center" />
                            </Border>
                            <Label
                                FontFamily="OpenSansSemibold"
                                FontSize="20"
                                HorizontalTextAlignment="Center"
                                Text="Her şey yolunda!"
                                TextColor="{AppThemeBinding Light={StaticResource SlateHeader},
                                                            Dark={StaticResource White}}" />
                            <Label
                                FontFamily="OpenSansRegular"
                                FontSize="15"
                                HorizontalTextAlignment="Center"
                                LineHeight="1.25"
                                Text="Şu an bekleyen bir görev yok. Ders materyalin varsa yükle; akışını buradan takip etmeye başla."
                                TextColor="{AppThemeBinding Light={StaticResource SlateSubtitle},
                                                            Dark={StaticResource SlateSubtitleDark}}" />
                            <Button
                                Margin="0,8,0,0"
                                Padding="28,14"
                                BackgroundColor="{AppThemeBinding Light={StaticResource IndigoBrand},
                                                                  Dark={StaticResource IndigoBrandDark}}"
                                BorderWidth="0"
                                Command="{Binding GoToSyllabusCommand}"
                                CornerRadius="14"
                                FontFamily="OpenSansSemibold"
                                FontSize="16"
                                HeightRequest="52"
                                HorizontalOptions="Center"
                                MinimumWidthRequest="220"
                                Text="Müfredat yükle"
                                TextColor="White">
                                <Button.Shadow>
                                    <Shadow
                                        Brush="#406366F1"
                                        Opacity="0.4"
                                        Radius="16"
                                        Offset="0,6" />
                                </Button.Shadow>
                            </Button>
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:TaskItemResponseDto">
                            <Border
                                Margin="0,0,0,10"
                                Padding="14"
                                BackgroundColor="{AppThemeBinding Light={StaticResource White},
                                                                  Dark={StaticResource FieldFillDark}}"
                                Stroke="{AppThemeBinding Light=#E0E7FF,
                                                          Dark=#3730A3}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 12">
                                <VerticalStackLayout Spacing="6">
                                    <Label
                                        FontAttributes="Bold"
                                        Text="{Binding Title}"
                                        TextColor="{AppThemeBinding Light={StaticResource SlateHeader},
                                                                    Dark={StaticResource White}}" />
                                    <Label
                                        Opacity="0.88"
                                        Text="{Binding CourseCode, StringFormat='Ders: {0}'}"
                                        TextColor="{AppThemeBinding Light={StaticResource SlateSubtitle},
                                                                    Dark={StaticResource SlateSubtitleDark}}" />
                                    <Label
                                        Opacity="0.88"
                                        Text="{Binding CourseTitle, StringFormat='{0}'}"
                                        TextColor="{AppThemeBinding Light={StaticResource SlateSubtitle},
                                                                    Dark={StaticResource SlateSubtitleDark}}" />
                                    <Label
                                        Opacity="0.88"
                                        Text="{Binding DueDate, StringFormat='Son tarih: {0:d}'}"
                                        TextColor="{AppThemeBinding Light={StaticResource SlateSubtitle},
                                                                    Dark={StaticResource SlateSubtitleDark}}" />
                                    <Label
                                        Opacity="0.88"
                                        Text="{Binding PriorityScore, StringFormat='Öncelik: {0}'}"
                                        TextColor="{AppThemeBinding Light={StaticResource SlateSubtitle},
                                                                    Dark={StaticResource SlateSubtitleDark}}" />
                                    <Label
                                        Opacity="0.75"
                                        Text="{Binding Description}"
                                        TextColor="{AppThemeBinding Light={StaticResource Gray600},
                                                                    Dark={StaticResource Gray300}}" />
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </RefreshView>
        </Grid>

        <!-- Snack-bar (üstten) -->
        <Border
            x:Name="SnackbarHost"
            Margin="16,8"
            Padding="14,12"
            HorizontalOptions="Fill"
            IsVisible="False"
            Stroke="{AppThemeBinding Light=#FCA5A5,
                                     Dark=#7F1D1D}"
            StrokeThickness="1"
            TranslationY="-180"
            VerticalOptions="Start"
            ZIndex="100"
            BackgroundColor="{AppThemeBinding Light={StaticResource SnackErrorBgLight},
                                               Dark={StaticResource SnackErrorBgDark}}">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12" />
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow
                    Brush="#40000000"
                    Opacity="0.25"
                    Radius="12"
                    Offset="0,4" />
            </Border.Shadow>
            <Label
                x:Name="SnackbarLabel"
                FontFamily="OpenSansRegular"
                FontSize="14"
                LineBreakMode="WordWrap"
                TextColor="{AppThemeBinding Light={StaticResource SnackErrorTextLight},
                                            Dark={StaticResource SnackErrorTextDark}}" />
        </Border>
    </Grid>
</ContentPage>

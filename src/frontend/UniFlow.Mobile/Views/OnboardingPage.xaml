<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="UniFlow.Mobile.Views.OnboardingPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:UniFlow.Mobile.ViewModels"
    x:DataType="vm:OnboardingViewModel"
    Style="{StaticResource UniFlowPage}"
    Title="Profilini tamamla">
    <ScrollView>
        <VerticalStackLayout Padding="24,20" Spacing="16">
            <VerticalStackLayout Spacing="6">
                <Label Style="{StaticResource UniFlowPageTitle}" Text="Hoş geldin" />
                <Label
                    Style="{StaticResource UniFlowPageSubtitle}"
                    Text="UniFlow deneyimini kişiselleştirmek için birkaç bilgi paylaş." />
            </VerticalStackLayout>

            <Border Style="{StaticResource UniFlowCard}">
                <VerticalStackLayout Spacing="14">
                    <Entry Placeholder="Görünen ad" Text="{Binding DisplayName}" />
                    <Entry Placeholder="Bölüm / Major" Text="{Binding Major}" />
                    <Editor
                        AutoSize="TextChanges"
                        HeightRequest="90"
                        Placeholder="Akademik hedefin"
                        Text="{Binding AcademicGoal}" />
                    <Border Style="{StaticResource UniFlowFilterShell}">
                        <Picker
                            ItemDisplayBinding="{Binding Label}"
                            ItemsSource="{Binding PersonalityOptions}"
                            SelectedItem="{Binding SelectedPersonality}"
                            Title="Motivasyon tarzı" />
                    </Border>
                    <Entry
                        Keyboard="Numeric"
                        Placeholder="Günlük çalışma hedefi (dakika)"
                        Text="{Binding DailyStudyTargetMinutes}" />
                </VerticalStackLayout>
            </Border>

            <Label
                Text="{Binding StatusMessage}"
                TextColor="{AppThemeBinding Light=#C62828, Dark=#FF8A80}" />
            <ActivityIndicator
                HorizontalOptions="Center"
                Color="{AppThemeBinding Light={StaticResource IndigoBrand}, Dark={StaticResource IndigoBrandDark}}"
                IsRunning="{Binding IsBusy}"
                IsVisible="{Binding IsBusy}" />

            <Button
                Style="{StaticResource UniFlowPrimaryButton}"
                Command="{Binding SaveCommand}"
                Text="Kaydet ve devam et" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

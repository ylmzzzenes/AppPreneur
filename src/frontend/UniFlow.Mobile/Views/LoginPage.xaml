<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="UniFlow.Mobile.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:UniFlow.Mobile.ViewModels"
    x:DataType="vm:LoginViewModel"
    Title="Giriş">
    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">
            <Label
                FontAttributes="Bold"
                FontSize="28"
                Text="UniFlow" />
            <Label Text="Hesabınla giriş yap." />
            <Entry
                Keyboard="Email"
                Placeholder="E-posta"
                Text="{Binding Email}" />
            <Entry
                IsPassword="True"
                Placeholder="Şifre"
                Text="{Binding Password}" />
            <Label
                Text="{Binding StatusMessage}"
                TextColor="{AppThemeBinding Light=#C62828,
                                            Dark=#FF8A80}" />
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />
            <Button Command="{Binding LoginCommand}" Text="Giriş yap" />
            <Button Command="{Binding OpenRegisterCommand}" Text="Hesap oluştur" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

{
  "Database": {
    "Provider": "PostgreSql"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=uniflow;Username=uniflow;Password=CHANGE_ME"
  },
  "Jwt": {
    "Issuer": "UniFlow",
    "Audience": "UniFlow.Mobile",
    "Key": "",
    "AccessTokenMinutes": 120
  },
  "SyllabusTextStorage": {
    "MaxStoredSourceTextLength": 4000,
    "MaxStoredPreviewJsonLength": 20000,
    "StoreRawSourceText": false,
    "StoreAiRawResponse": false,
    "StorePreviewJson": true,
    "NormalizeBeforeHashing": true
  },
  "UniFlow": {
    "Ocr": {
      "Provider": "Stub",
      "Azure": {
        "Endpoint": "",
        "ApiKey": ""
      },
      "Tesseract": {
        "DataPath": "",
        "Language": "eng"
      }
    },
    "Gemini": {
      "ApiKey": "",
      "Model": "gemini-2.0-flash",
      "TimeoutSeconds": 120
    }
  },
  "RateLimiting": {
    "Ai": {
      "PermitLimit": 10,
      "WindowSeconds": 60
    },
    "Upload": {
      "PermitLimit": 5,
      "WindowSeconds": 60
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}

    "Provider": "SqlServer"
  },
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Jwt": {
    "Issuer": "UniFlow",
    "Audience": "UniFlow.Mobile",
    "Key": "",
    "AccessTokenMinutes": 120
  },
  "SyllabusTextStorage": {
    "MaxStoredSourceTextLength": 4000,

    "RetryCount": 2,
    "PromptVersion": "v1",
    "EnableFallback": true,
    "LogMetadataOnly": true,
    "ChatSystemPrompt": ""
  },
  "UniFlow": {
    "Ocr": {
      "Provider": "Stub",
      "Azure": {
        "Endpoint": "",
        "ApiKey": ""
      },
      "Tesseract": {
        "DataPath": "",
        "Language": "eng"
      }
    },
    "Gemini": {
      "ApiKey": "",
      "Model": "gemini-2.5-flash",
      "TimeoutSeconds": 120
    }
  },
  "RateLimiting": {
    "Ai": {
      "PermitLimit": 10,
      "WindowSeconds": 60

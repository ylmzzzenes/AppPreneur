{
  "ConnectionStrings": {
    "DefaultConnection": "DataSource=UniFlowIntegrationTests;Mode=Memory;Cache=Shared"
  },
  "Jwt": {
    "Issuer": "UniFlow",
    "Audience": "UniFlow.Mobile",
    "Key": "test-jwt-signing-key-minimum-32-characters-long!",
    "AccessTokenMinutes": 60
  },
  "SyllabusTextStorage": {
    "MaxStoredSourceTextLength": 4000,
    "MaxStoredPreviewJsonLength": 20000,
    "StoreRawSourceText": false,
    "StoreAiRawResponse": false,
    "StorePreviewJson": true,
    "NormalizeBeforeHashing": true
  },
  "UniFlow": {
    "Ocr": {
      "Provider": "Stub"
    },
    "Gemini": {
      "ApiKey": "",
      "Model": "gemini-2.0-flash",
      "TimeoutSeconds": 120
    }
  },
  "RateLimiting": {
    "Ai": {
      "PermitLimit": 1000,
      "WindowSeconds": 60
    },
    "Upload": {
      "PermitLimit": 1000,
      "WindowSeconds": 60
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
